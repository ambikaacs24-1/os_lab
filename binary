#include <stdio.h>
int main() {
    int n, target, low, high, mid;

    printf("Enter number of elements: ");
    scanf("%d", &n);
    int arr[n];

    printf("Enter elements");
    for (int i = 0; i < n; i++){
        scanf("%d", &arr[i]);

    } 

    printf("Enter value to find: ");
    scanf("%d", &target);

    low = 0;
    high = n - 1;

    while (low <= high) {
        mid = low + (high - low) / 2;
        if (arr[mid] == target) {
            printf("Found %d at index %d.\n", target, mid);
            return 0;
        }
        if (arr[mid] < target) {
            low = mid + 1;}
        else {
            high = mid - 1;
            }
    }
    printf("Not found");
    return 0;
}
