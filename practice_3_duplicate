#include <stdio.h>

int main() {
    int n, found = 0;
    printf("Enter no of elements ");
    scanf("%d", &n);
    int arr[n];

    printf("enter elements:\n");
    for (int i = 0; i < n; i++){
        scanf("%d", &arr[i]);
    } 

    
    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {
            if (arr[i] == arr[j]) {
                
                found = 1;
                break; 
            }
        }
    }

    if (found!=1){
        printf("no duplicates");
        } 
    else{
        printf("duplicate found ")
    }
    
    return 0;
}
